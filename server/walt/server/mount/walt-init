#!/bin/busybox sh

ROOTFS='/run/walt/rootfs'
ROOTFS_EXECUTABLES="
    basename cat chroot cp date grep ln ls mkdir mkfifo mktemp
    mount mv nc reboot rm sed sh sleep timeout umount uname
"

. bin/_walt_internal_/walt-boot-modes  # needed for need_rw_nfsroot()

_run_is_mounted() {
    walt_mount | nostdout busybox grep " /run "
}

do_mounts()
{
    # mount /proc and /sys if missing, and if that is the case,
    # record that for cleanup up before running the final init.
    if [ -e "/proc/self" ]
    then
        export had_procfs=1
    else
        walt_mount -t proc proc /proc
        export had_procfs=0
    fi
    if [ -d "/sys/class" ]
    then
        export had_sysfs=1
    else
        walt_mount -t sysfs sysfs /sys
        export had_sysfs=0
    fi
    # mount /dev and /run if missing.
    # in any case, we will not umount them before running the final init
    # because walt bg processes need them.
    if [ ! -e "/dev/null" ]
    then
        walt_mount -t devtmpfs udev /dev
    fi
    if ! _run_is_mounted
    then
        walt_mount -t tmpfs tmpfs /run
    fi
}

preinit() {
    if [ -x "/bin/walt-preinit" ]
    then
        boot_step_label_cr          "Calling /bin/walt-preinit..."
        /bin/walt-preinit
    fi
    # call walt_preinit() optional function too,
    # if defined in walt-init-overrides.
    walt_preinit
}

prepare_rootfs()
{
    busybox mkdir -p $ROOTFS
    # $ROOTFS must be a mountpoint for pivot_root() to work later
    walt_mount -t tmpfs tmpfs $ROOTFS
    cd $ROOTFS
    busybox mkdir -p tmp bin mnt/nfsroot
    copy_exec_to_rootfs busybox
    if nostdout busybox which nbd-client
    then
        copy_exec_to_rootfs nbd-client
    fi
    for image_script in /bin/walt-* /bin/_walt_internal_/*
    do
        cp $image_script bin/
    done
    for c in $ROOTFS_EXECUTABLES
    do
        if [ ! -e bin/$c ]
        then
            if busybox_has_applet $c
            then
                ln -s busybox bin/$c
            else
                copy_exec_to_rootfs $c
            fi
        fi
    done
    for fs_dir in proc sys dev run
    do
        ln -s mnt/nfsroot/$fs_dir $fs_dir
    done
    dump_walt_env > bin/walt-env
    walt_populate_rootfs_custom
}

remount_nfsroot_if_needed()
{
    if need_rw_nfsroot
    then
        boot_step_label_cr "Ensuring the remote filesystem" \
                           "is read-write..."
        walt_mount -o remount,rw /
    fi
}

mount_persistent() {
    if [ -z "${walt_persist_path}" ]
    then
        echo "/persist was not mounted (cf. walt node config)"
        return
    fi
    mkdir $ROOTFS/persist
    walt_mount_persistent "$walt_persist_path" $ROOTFS/persist
    # check if walt-init logs are enabled
    walt_init_log_dir="$ROOTFS/persist/logs/walt-init"
    if [ -d "$walt_init_log_dir" ]
    then
        # avoid NFS buffers by remounting with 'sync' option.
        # note: "mount -o remount,sync" fails on some systems,
        # so we umount + mount again.
        walt_umount $ROOTFS/persist
        walt_mount_persistent --sync "$walt_persist_path" $ROOTFS/persist
    fi
}

switch_to_rootfs() {
    cd $ROOTFS
    walt_switch_root_fs mnt/nfsroot \
        bin/walt-init-rootfs "$@"
}

# let's go
export PATH="$PATH:/bin/_walt_internal_"
export walt_init_done=0
# preparation work
. walt-script-common
# redefine console
cd /; walt_set_console
# run image's preinit code if any
preinit
# Check we are PID 1.
if [ "$$" -ne 1 ]
then
    echo "This is the init script of walt nodes." >&2
    echo "It is only useful when the node is booting. Exiting." >&2
    exit 1
fi
# real start
walt-log-echo "walt-init" "Starting up."
boot_step_label_cr          "Initializing..."
do_mounts
walt_set_console  # in case do_mounts() just mounted /dev
walt_load_kernel_modules
prepare_rootfs
boot_step_label_cr          "Mounting /persist..."
mount_persistent
remount_nfsroot_if_needed
boot_step_label_cr          "Switching to rootfs..."
switch_to_rootfs "$@"
# the process continues in bin/_walt_internal_/walt-init-rootfs
