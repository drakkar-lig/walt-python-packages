#!/bin/busybox sh

switch_to_finalfs() {
    cd /mnt/finalfs
    # dump updated walt-env file
    dump_walt_env > bin/walt-env
    # bind /run on top of finalfs
    walt_mount -o bind /mnt/nfsroot/run run
    # /persist may be disabled by using "walt node config", in this case
    # the directory was not created.
    if [ -d "/persist" ]
    then
        # finalfs:/persist will be a symlink to current rootfs mount
        [ -e "persist" ] && rm -rf persist
        ln -sf /run/walt/rootfs/persist persist
    fi
    # /dev may just be a directory with special files, not a mountpoint.
    # We'll need to keep a valid /dev in the rootfs anyway, for bg scripts
    # (e.g. /dev/null, etc.), so don't move it, just bind it.
    if [ ! -e dev/null ]
    then
        walt_mount -o bind /mnt/nfsroot/dev dev
    fi
    # /proc and /sys: we try to make the system ressemble what we got
    # when called.
    # bg scripts will need /proc in the rootfs too (e.g., for /proc/uptime)
    # but not /sys.
    if [ "$had_procfs" -eq 1 ]
    then
        walt_mount -o bind /mnt/nfsroot/proc proc
    fi
    if [ "$had_sysfs" -eq 1 ]
    then
        walt_mount -o move /mnt/nfsroot/sys sys
    else
        walt_umount /mnt/nfsroot/sys
    fi
    rm /sys  # no longer needed in the rootfs anyway
    # switch root to final fs
    walt_switch_root_fs run/walt/rootfs \
        bin/_walt_internal_/walt-init-finalfs "$@"
}

. walt-script-common
# continue with walt-init-rootfs-main
walt-log-script fg walt-init-rootfs-main
# switch to finalfs
boot_step_label_cr          "Switching to finalfs..."
switch_to_finalfs "$@"
# the process continues in bin/_walt_internal_/walt-init-finalfs
